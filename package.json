{
  "name": "penny-vault-frontend-ng",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --build --force && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,vue,js,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,js,json,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "types:generate": "openapi-typescript ../pv-api/openapi/openapi.yaml -o src/api/types.ts"
  },
  "dependencies": {
    "@auth0/auth0-vue": "^2.5.0",
    "@revolist/vue3-datagrid": "^4.21.4",
    "@tanstack/vue-query": "^5.99.0",
    "echarts": "^5.5.1",
    "marked": "^18.0.2",
    "ofetch": "^1.5.1",
    "pinia": "^2.3.1",
    "primeicons": "^7.0.0",
    "primevue": "^4.2.5",
    "vue": "^3.5.13",
    "vue-echarts": "^7.0.3",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@primevue/themes": "^4.2.5",
    "@types/node": "^22.19.17",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/ui": "^4.1.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^9.33.0",
    "jsdom": "^25.0.1",
    "msw": "^2.13.4",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "vue-tsc": "^2.2.12"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
